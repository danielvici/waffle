{
  "name": "waffle-web",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxi dev",
    "dev:pwa": "VITE_PLUGIN_PWA=true nuxi dev",
    "release": "bun run lint && bun run typecheck && bun run build && changelogen --release --push",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "postinstall": "nuxi prepare",
    "lint": "eslint . --fix",
    "typecheck": "nuxi typecheck",
    "prepare": "husky install",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@network-utils/tcp-ping": "^1.2.3",
    "@vueuse/nuxt": "^12.8.2",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "h3-zod": "^0.5.3",
    "rollup": "npm:@rollup/wasm-node",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.27.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@hywax/vitepress-yandex-metrika": "^0.4.0",
    "@nuxt/devtools": "latest",
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/i18n": "^9.3.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^20.19.41",
    "@vite-pwa/nuxt": "^0.10.8",
    "changelogen": "^0.5.7",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nuxt": "^3.21.7",
    "nuxt-icon": "^0.6.10",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vue-tsc": "^2.2.12"
  },
  "resolutions": {
    "rollup": "npm:@rollup/wasm-node"
  },
  "lint-staged": {
    "*.ts": "yarn run lint"
  }
}
