{
  "version": "2",
  "templates": [
    {
      "categories": [
        "Dashboard"
      ],
      "description": "Waffle is a lightweight and easy to use Homepage. The Goal is to keep a Homepage as simple as possible AND to be highly customizible!",
      "image": "danielvici/waffle:latest",
      "logo": "https://mafl.hywax.space/logotype.svg", // TODO: Change it
      "name": "Waffle",
      "platform": "linux",
      "ports": [
        "3000:3000/tcp"
      ],
      "restart_policy": "unless-stopped",
      "title": "Waffle",
      "type": 1,
      "volumes": [
        {
          "bind": "/portainer/Files/AppData/Config/Mafl/config.yml",
          "container": "/app/data/config.yml"
        }
      ]
    }
  ]
}
