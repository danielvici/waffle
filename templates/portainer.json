{
  "version": "2",
  "templates": [
    {
      "categories": [
        "Dashboard"
      ],
      "description": "All your self-hosted apps on one plate. Tasty as you love it. A dashboard that just works.",
      "image": "ghcr.io/danielvici/waffle:latest",
      "logo": "https://raw.githubusercontent.com/danielvici/waffle/main/waffle_logo_round.svg",
      "name": "Waffle",
      "platform": "linux",
      "ports": [
        "3000:3000/tcp"
      ],
      "restart_policy": "unless-stopped",
      "title": "Waffle",
      "type": 1,
      "volumes": [
        {
          "bind": "/portainer/Files/AppData/Config/Mafl/config.yml",
          "container": "/app/data/config.yml"
        }
      ]
    }
  ]
}
