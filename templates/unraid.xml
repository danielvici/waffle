<?xml version="1.0"?>
<Container version="2">
    <Name>waffle</Name>
    <Repository>danielvici/waffle</Repository>
    <Registry>https://ghcr.io/danielvici/waffle</Registry>
    <Network>bridge</Network>
    <Privileged>false</Privileged>
    <Support>https://github.com/danielvici/waffle</Support>
    <Shell>sh</Shell>
    <Branch>
        <Tag>latest</Tag>
        <TagDescription>Stable releases from GitHub</TagDescription>
    </Branch>
    <Project>https://github.com/danielvici/waffle/</Project>
    <Overview>Waffle is a lightweight and easy to use Homepage. The Goal is to keep a Homepage as simple as possible AND to be highly customizible!</Overview>
    <WebUI>http://[IP]:[PORT:3000]</WebUI>
    <TemplateURL>false</TemplateURL>
    <Icon>https://mafl.hywax.space/logotype.svg</Icon> <!--TODO: CHANGE IT -->
    <Config Name="WebUI Port" Target="3000" Default="3000" Mode="tcp" Description="Web UI Port" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
    <Config Name="Config" Target="/app/data/config.yml" Default="/mnt/user/appdata/waffle/config.yaml" Mode="ro" Description="" Type="Path" Display="always" Required="true" Mask="false"/>
    <Config Name="Local Icons" Target="/app/public/favicons" Default="/mnt/user/appdata/waffle/favicons" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false"/>
    <Config Name="Favicon Icons" Target="/app/public/icons" Default="/mnt/user/appdata/waffle/icons" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false"/>
</Container>
